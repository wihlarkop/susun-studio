{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Susun Studio",
  "version": "0.1.0",
  "identifier": "com.edo.susun-studio",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:sidecar && bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Susun Studio",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:*; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/susun-studio-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQjFGRkU0QjgzNDBENDMKUldSRERUUzQ1UCt4ZlMvaDh4M2d0Y3FMM3lEOUc5U3Bta2crd3FwUjBQWEppVW1RMHBWRVVnQVcK",
      "endpoints": [
        "https://github.com/wihlarkop/susun-studio/releases/latest/download/latest.json"
      ]
    }
  }
}
