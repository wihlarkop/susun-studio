{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "log:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/susun-studio-daemon", "sidecar": true }]
    }
  ]
}
